# ============================================================
# Enhanced Search MCP - Environment Configuration
# Copy this file to .env and modify as needed
# ============================================================

# --- SearXNG Instance ---
# Local Docker instance (default, recommended)
SEARXNG_URL=http://localhost:8888/
# Remote instance (alternative):
# SEARXNG_URL=http://your-server-ip:8888/

# --- Search Engine Selection ---
# Comma-separated list of SearXNG engines for general search
# China-optimized defaults (verified accessible without VPN):
SEARXNG_DEFAULT_ENGINES=bing,baidu,sogou,360search,mojeek,presearch
# International (if server has unrestricted network):
# SEARXNG_DEFAULT_ENGINES=bing,google,duckduckgo,baidu,wikipedia

# Comma-separated list for image search
SEARXNG_IMAGE_ENGINES=sogou images,unsplash,pexels,mojeek images,presearch images
# International:
# SEARXNG_IMAGE_ENGINES=bing images,google images,unsplash,pexels,pixabay images

# --- DuckDuckGo ---
# Disable in China (blocked), enable if server has unrestricted network
ENABLE_DDG=false

# --- Timeouts (seconds) ---
SEARCH_TIMEOUT=30
SEARCH_OP_TIMEOUT=15
FETCH_OP_TIMEOUT=30
DEEP_SEARCH_OP_TIMEOUT=60

# --- Limits ---
DEFAULT_LIMIT=10
DEEP_SEARCH_MAX_PAGES=5
MAX_CONTENT_LENGTH=10000
RATE_LIMIT_RPM=200
MAX_CONCURRENT=20

# --- Cache (optional, requires redis) ---
# Leave empty to disable caching
REDIS_URL=
# Enable caching:
# REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# --- Health Check ---
HEALTH_CHECK_INTERVAL=300

# --- Optional Features ---
ENABLE_PLAYWRIGHT=false

# --- Docker SearXNG Settings ---
SEARXNG_PORT=8888
SEARXNG_IMAGE=searxng/searxng:latest
# China mirror (if Docker Hub is slow):
# SEARXNG_IMAGE=docker.1ms.run/searxng/searxng:latest
